{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component-icons.schema.json",
  "type": "object",
  "additionalProperties": false,
  "description": "Icon for the component in Matrix and the DXP. Uses Font Awesome icon names (without 'fa-' prefix).",
  "properties": {
    "id": {
      "type": "string",
      "description": "Font Awesome icon name (e.g., 'home', 'magnifying-glass', 'code'). Will be rendered as 'fa-light fa-{id}' in the NT Gov Design System.",
      "enum": [
        "home",
        "bars",
        "times",
        "xmark",
        "chevron-down",
        "chevron-up",
        "chevron-left",
        "chevron-right",
        "arrow-left",
        "arrow-right",
        "arrow-up",
        "arrow-down",
        "ellipsis",
        "ellipsis-vertical",
        "angles-down",
        "angles-up",
        "caret-down",
        "caret-up",
        "magnifying-glass",
        "search",
        "filter",
        "sliders",
        "sort",
        "plus",
        "minus",
        "edit",
        "pen",
        "trash",
        "trash-can",
        "save",
        "floppy-disk",
        "copy",
        "download",
        "upload",
        "share",
        "share-nodes",
        "print",
        "refresh",
        "rotate",
        "rotate-right",
        "undo",
        "redo",
        "check",
        "ban",
        "link",
        "link-slash",
        "file",
        "file-lines",
        "file-pdf",
        "file-word",
        "file-excel",
        "file-image",
        "file-code",
        "file-zipper",
        "folder",
        "folder-open",
        "clipboard",
        "envelope",
        "paper-plane",
        "book",
        "info-circle",
        "circle-info",
        "exclamation-circle",
        "circle-exclamation",
        "exclamation-triangle",
        "triangle-exclamation",
        "check-circle",
        "circle-check",
        "times-circle",
        "circle-xmark",
        "question-circle",
        "circle-question",
        "bell",
        "circle-notch",
        "spinner",
        "user",
        "user-circle",
        "users",
        "user-group",
        "lock",
        "unlock",
        "key",
        "sign-out",
        "right-from-bracket",
        "sign-in",
        "right-to-bracket",
        "gear",
        "cog",
        "sliders-h",
        "wrench",
        "screwdriver-wrench",
        "eye",
        "eye-slash",
        "image",
        "play",
        "pause",
        "volume-up",
        "volume-high",
        "map-marker",
        "map-marker-alt",
        "location-dot",
        "calendar",
        "calendar-days",
        "calendar-alt",
        "clock",
        "phone",
        "comment",
        "comments",
        "message",
        "messages",
        "chart-bar",
        "chart-line",
        "table",
        "list",
        "list-ul",
        "list-ol",
        "font",
        "text-height",
        "universal-access",
        "closed-captioning",
        "external-link",
        "up-right-from-square",
        "grip",
        "grip-vertical",
        "code",
        "building",
        "landmark",
        "id-card",
        "briefcase",
        "handshake",
        "shield",
        "shield-halved",
        "star",
        "heart",
        "thumbs-up",
        "thumbs-down",
        "flag",
        "bookmark",
        "tag",
        "tags",
        "paperclip",
        "lightbulb",
        "bolt",
        "cloud",
        "database",
        "server",
        "network-wired",
        "globe",
        "earth-americas",
        "wifi",
        "mobile",
        "mobile-screen-button",
        "tablet",
        "laptop",
        "desktop",
        "tv",
        "keyboard",
        "mouse",
        "camera",
        "video",
        "microphone",
        "headphones",
        "graduation-cap",
        "award",
        "certificate",
        "medal",
        "trophy",
        "gift",
        "truck",
        "car",
        "bus",
        "train",
        "plane",
        "ship",
        "bicycle",
        "wheelchair",
        "hospital",
        "ambulance",
        "house",
        "tree",
        "leaf",
        "seedling",
        "fire",
        "droplet",
        "sun",
        "moon",
        "recycle"
      ]
    },
    "color": {
      "description": "Color of the icon in the DXP interface",
      "oneOf": [
        {
          "title": "ColorHex",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "hex"
            },
            "value": {
              "type": "string",
              "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
            }
          },
          "required": ["type", "value"]
        },
        {
          "title": "ColorEnum",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "enum"
            },
            "value": {
              "enum": [
                "gray",
                "blue",
                "green",
                "orange",
                "red",
                "purple",
                "teal",
                "yellow",
                "pink"
              ]
            }
          },
          "required": ["type", "value"]
        }
      ]
    }
  },
  "required": ["id", "color"]
}
